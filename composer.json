{
    "name": "lmate/laravel-google-drive",
    "description": "Filesystem adapter for Google Drive",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lifa Matemba",
            "email": "lmatemba5@gmail.com"
        }
    ],
    "require": {
        "php": "^8",
        "illuminate/support": "^10",
        "illuminate/console": "^10",
        "illuminate/config": "^10",
        "google/apiclient": "^2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1",
        "phpro/grumphp": "^v2",
        "mockery/mockery": "^1.6.2"
    },
    "autoload": {
        "psr-4": {
            "Lmate\\LaravelGoogleDrive\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpro/grumphp": true
        }
    },
    "minimum-stability": "dev"
}
